# Copy to .env and adjust. Never commit real secrets.

POSTGRES_USER=peladas
POSTGRES_PASSWORD=peladas
POSTGRES_DB=peladas
POSTGRES_PORT=5432

API_PORT=3001
WEB_JOGADOR_PORT=3002
WEB_ADMIN_PORT=3003

# Postgres inside Docker network (used by api service)
DATABASE_URL=postgresql://peladas:peladas@db:5432/peladas?schema=public

# Prisma on the host (migrate/seed): copy apps/api/.env.example -> apps/api/.env
# with localhost URL below — Prisma does not read DATABASE_URL from this root .env file.
# DATABASE_URL=postgresql://peladas:peladas@localhost:5432/peladas?schema=public
