# Copy to .env in this directory. Prisma CLI loads .env from apps/api (not repo root).
DATABASE_URL=postgresql://peladas:peladas@localhost:5432/peladas?schema=public

# Segredo HS256 para JWT (login). Mesmo valor nas apps Next (`JWT_SECRET`) para o middleware validar o cookie.
JWT_SECRET=dev-jwt-secret-change-in-production

# Opcional: Google Places (Autocomplete + Place Details) só na API. Sem chave, sugestões ficam vazias e criar a partir do Google fica desativado.
# GOOGLE_PLACES_API_KEY=
